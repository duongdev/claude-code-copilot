# Copy to `.env` (same directory as docker-compose.yml) and fill in values.
# `docker compose up -d` picks this file up automatically — no shell exports needed.
# All values are optional except COPILOT_PROXY_API_KEY when exposing the proxy
# beyond localhost.

# Shared secret clients must send as Authorization / x-api-key / api-key header.
# Leave unset only when the proxy is loopback-only.
COPILOT_PROXY_API_KEY=

# Web search provider (optional — falls back to DuckDuckGo Lite).
BRAVE_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# Compaction + truncation tuning. Defaults shown.
COPILOT_MAX_PROMPT_TOKENS=115000
COPILOT_TOOL_RESULT_MAX_CHARS=25000
COPILOT_KEEP_RECENT_TOOL_RESULTS=2

# Override per-model max_tokens default. Empty = model-aware default
# (16K opus/sonnet-4.6+, 8K others).
COPILOT_DEFAULT_MAX_OUTPUT=
